{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Default capability granted to the main window. Lets the frontend invoke our IPC commands and open native open/save file dialogs.",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "core:window:allow-start-dragging",
    "core:window:allow-toggle-maximize",
    "dialog:allow-open",
    "dialog:allow-save",
    "updater:default",
    "process:allow-restart"
  ]
}
